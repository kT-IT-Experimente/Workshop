        "method": "GET",
        "url": "=https://query1.finance.yahoo.com/v8/finance/chart/{{$fromAI(\"ticker\")}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "User-Agent",
              "value": "Mozilla/5.0"
            }
          ]
        }
      },
