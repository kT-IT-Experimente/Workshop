      "typeVersion": 1,
      "position": [
        860,
        500
      ]
    },
    {
      "parameters": {
        "name": "JinaReader",
        "description": "Call this tool to convert any URL into clean Markdown for LLM consumption. Pass the URL as the parameter.",
        "method": "GET",
        "url": "=https://r.jina.ai/{{$fromAI(\"url\")}}"
      },
      "id": "tool-jina-123",
      "name": "Jina Reader Tool",
