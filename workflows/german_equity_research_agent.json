        "description": "AI-optimized web/news search. Call this to search the web.",
        "method": "POST",
        "url": "https://api.tavily.com/search",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "query",
              "value": "={{$fromAI(\"query\")}}"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$vars.TAVILY_API_KEY}}"
            }
          ]
        }
      },
      "id": "tool-tavily-123",
